TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Symbols to monitor, separated by commas (lowercase)
# Default: btcusdt
MONITOR_SYMBOLS=btcusdt,ethusdt
PROXY_URL=

# Adaptive Z-Score Parameters
Z_SCORE_MULTIPLIER=3.0
MIN_VOLATILITY_THRESHOLD=0.002

# Cumulative Change Parameters (10m)
CUMULATIVE_THRESHOLD=0.005
CUMULATIVE_WINDOW=10

# Volume Spike Parameters
VOLUME_SPIKE_MULTIPLIER=5.0

# RSI Momentum Parameters
RSI_PERIOD=14
RSI_OVERBOUGHT=80
RSI_OVERSOLD=20

# Price Breakout Parameters (60m Window)
BREAKOUT_WINDOW=60
