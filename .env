# Symbols to monitor, separated by commas (lowercase)
# Default: btcusdt
MONITOR_SYMBOLS=btcusdt,ethusdt,solusdt
PROXY_URL=

# Adaptive Z-Score Parameters
Z_SCORE_MULTIPLIER=3.0
MIN_VOLATILITY_THRESHOLD=0.002

# Cumulative Change Parameters (10m)
CUMULATIVE_THRESHOLD=0.005
CUMULATIVE_WINDOW=10

# Volume Spike Parameters
VOLUME_SPIKE_MULTIPLIER=5.0

# RSI Momentum Parameters
RSI_PERIOD=14
RSI_OVERBOUGHT=80
RSI_OVERSOLD=20

# Price Breakout Parameters (60m Window)
BREAKOUT_WINDOW=60

# MACD Parameters
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# Bollinger Bands Parameters
BB_PERIOD=20
BB_STD=2.0

# ATR Parameters
ATR_PERIOD=14

# Multi-Timeframe RSI Confirmation
MULTI_RSI_CONFIRM=true

# Alert Control
ALERT_COOLDOWN=300

# Timeframe Enable/Disable
ENABLE_1M=true
ENABLE_5M=true
ENABLE_1H=true
ENABLE_1D=true

# Market Sentiment Features
ENABLE_FUNDING_RATE=true
ENABLE_FEAR_GREED=true
ENABLE_LONG_SHORT=true
